<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="24dp"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+-----------User Profile-----------+"
            android:textSize="24sp"
            android:textStyle="bold|italic"
            android:textColor="@color/primary_text"
            android:layout_marginBottom="24dp"/>

        <ImageView
            android:id="@+id/studentImage"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/azib_bg_white"
            android:contentDescription="Student Photo"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/txtName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MUHAMAD AZIB IZZUDIN BIN NORDIN"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_text"/>

        <TextView
            android:id="@+id/txtId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student ID: 2025148745"
            android:textSize="16sp"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/txtCourse"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ICT602 – Mobile Technology"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/linkGitHub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="https://github.com/Aziboss"
            android:textSize="14sp"
            android:textColorLink="@color/primary"
            android:autoLink="web"
            android:linksClickable="true"
            android:layout_marginTop="8dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/hint_text"
            android:layout_marginVertical="24dp"/>

        <!-- How to Use -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How to Use"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Select month from the dropdown.\n2. Enter electricity units used (1–1000 kWh).\n3. Adjust rebate slider (0–5%).\n4. Press 'Calculate &amp; Save' – result appears below.\n5. Click 'View History' to see all saved records.\n6. Tap any record to View, Update, or Delete.\n7. This About page shows my info and instructions."
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/hint_text"
            android:layout_marginVertical="24dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnBackToHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back to Home"
            android:backgroundTint="#757575"
            android:textColor="@android:color/white"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="© 2026 Azib Izzudin"
            android:textSize="12sp"
            android:textColor="@color/hint_text"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>